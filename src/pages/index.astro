---
/**
 * index.astro — chriscarolan.com one-page authority site.
 * Composition order per Figma render (one-page master):
 *   TopNav → Hero → ProofRow → ProblemStatement → HowICanHelp → WhyChris
 *   → ComparisonCard → ValueFirstTeam → MeetChris → SpeakingMedia → InTheMedia
 *   → PodcastSection → SpeakingKit → JustForFun → ReadyToConnect → Footer
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import TopNav from '../components/TopNav.astro';
import Hero from '../components/Hero.astro';
import ProofRow from '../components/ProofRow.astro';
import ProblemStatement from '../components/ProblemStatement.astro';
import HowICanHelp from '../components/HowICanHelp.astro';
import WhyChris from '../components/WhyChris.astro';
import ComparisonCard from '../components/ComparisonCard.astro';
import MeetChris from '../components/MeetChris.astro';
import SpeakingMedia from '../components/SpeakingMedia.astro';
import ValueFirstTeam from '../components/ValueFirstTeam.astro';
import InTheMedia from '../components/InTheMedia.astro';
import PodcastSection from '../components/PodcastSection.astro';
import SpeakingKit from '../components/SpeakingKit.astro';
import JustForFun from '../components/JustForFun.astro';
import ReadyToConnect from '../components/ReadyToConnect.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Chris Carolan" path="/">
  <TopNav />
  <Hero />
  <ProofRow />
  <ProblemStatement />
  <HowICanHelp />
  <WhyChris />
  <ComparisonCard />
  <ValueFirstTeam />
  <MeetChris />
  <SpeakingMedia />
  <InTheMedia />
  <PodcastSection />
  <SpeakingKit />
  <section class="cc-bottom-band">
    <JustForFun />
    <ReadyToConnect />
  </section>
  <Footer />
</BaseLayout>

<style>
  /* Bottom cosmic band — Figma places swirl image at y=9661 spanning the
     JustForFun + ReadyToConnect block. One image, two sections sitting on it.
     Veil fades top + bottom into navy so it reads as a contained band. */
  .cc-bottom-band {
    background:
      linear-gradient(180deg, #1C1B2D 0%, rgba(28, 27, 45, 0) 25%, rgba(28, 27, 45, 0) 75%, #1C1B2D 100%),
      url('/assets/bg-cosmic-particles.jpg') center center / cover no-repeat;
  }
</style>
