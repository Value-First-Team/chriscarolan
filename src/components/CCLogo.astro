---
/**
 * CCLogo — brand lockup: orange-gradient CC monogram + stacked "Chris / Carolan"
 * wordmark composed from live text (Kameron, cream).
 *
 * The SVG wordmark assets only contain "Carolan" — to render the Figma's stacked
 * two-line lockup we compose the type directly so both lines are present.
 */
interface Props {
  height?: number;
  color?: 'cream' | 'dark';
}

const { height = 50, color = 'cream' } = Astro.props;

const markWidth = Math.round(height * 1.375);
// Stacked wordmark sized to the mark — each line ~38% of mark height.
const lineSize = Math.round(height * 0.42);
const textColor = color === 'cream' ? 'var(--cc-pearl)' : 'var(--cc-prune)';
---

<div class="cc-logo" style={`height: ${height}px;`}>
  <div
    class="cc-logo-mark"
    style={`width: ${markWidth}px; height: ${height}px;`}
    aria-hidden="true"
  >
  </div>
  <div
    class="cc-logo-words"
    style={`font-size: ${lineSize}px; color: ${textColor};`}
    aria-label="Chris Carolan"
  >
    <span>Chris</span>
    <span>Carolan</span>
  </div>
</div>

<style>
  .cc-logo {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .cc-logo-mark {
    background: linear-gradient(180deg, #f5872b 0%, #f85f36 100%);
    -webkit-mask: url('/assets/logo-cc-mark-orange.svg') center / contain no-repeat;
    mask: url('/assets/logo-cc-mark-orange.svg') center / contain no-repeat;
    flex-shrink: 0;
  }
  .cc-logo-words {
    font-family: var(--cc-font-display);
    font-weight: 500;
    line-height: 0.95;
    letter-spacing: -0.01em;
    display: flex;
    flex-direction: column;
    justify-content: center;
    flex-shrink: 0;
  }
  .cc-logo-words span {
    display: block;
  }
</style>
