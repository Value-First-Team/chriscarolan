---
/**
 * JustForFun — photo left, dark card with section title + two short lines right.
 * Both lines are verbatim from Chris's brand discovery answers (Q6/Q8).
 */
const lines = [
  'I do my best work in conversation, not behind the scenes.',
  'I don’t set revenue goals. I focus on value and let the results follow.',
];
---

<section class="cc-fun">
  <div class="cc-fun-frame">
    <div class="cc-fun-photo" aria-hidden="true"></div>
    <div class="cc-fun-card">
      <div class="cc-fun-card-inner">
        <h2>Just for Fun</h2>
        {lines.map((l) => <div class="cc-fun-line">{l}</div>)}
      </div>
    </div>
  </div>
</section>

<style>
  .cc-fun {
    padding: 60px clamp(24px, 16vw, 314px);
  }
  .cc-fun-frame {
    position: relative;
    min-height: 700px;
  }
  .cc-fun-photo {
    position: absolute;
    left: 55px;
    top: 22px;
    width: 55%;
    height: calc(100% - 44px);
    border-radius: 0 0 0 25px;
    background-image: url('/assets/chris-portrait-justforfun.png');
    background-size: cover;
    background-position: center 20%;
    z-index: 2;
  }
  .cc-fun-card {
    position: absolute;
    right: 0;
    top: 86px;
    width: 70%;
    height: 600px;
    border-radius: 25px;
    background-color: #171625;
    padding: 75px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 22px;
    align-items: flex-end;
    z-index: 1;
  }
  .cc-fun-card-inner {
    width: 495px;
    max-width: 100%;
    display: flex;
    flex-direction: column;
    gap: 22px;
  }
  .cc-fun-card h2 {
    font-family: var(--cc-font-display);
    font-weight: 500;
    font-size: clamp(36px, 4.2vw, 64px);
    line-height: 1;
    color: var(--cc-mirinda-deep);
    margin: 0;
  }
  .cc-fun-line {
    font-family: var(--cc-font-body);
    font-size: clamp(18px, 2vw, 22px);
    line-height: 1.45;
    color: var(--cc-pearl);
  }
  @media (max-width: 900px) {
    .cc-fun {
      padding: 40px 24px;
    }
    .cc-fun-frame {
      min-height: 0;
    }
    .cc-fun-photo {
      position: relative;
      left: 0;
      top: 0;
      width: 100%;
      height: 280px;
      border-radius: 25px;
      margin-bottom: 24px;
    }
    .cc-fun-card {
      position: relative;
      top: 0;
      width: 100%;
      height: auto;
      padding: 40px;
      align-items: flex-start;
    }
  }
</style>
