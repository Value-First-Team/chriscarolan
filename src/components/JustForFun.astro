---
/**
 * JustForFun — cream card on the navy page.
 *
 * Layout: Chris portrait (green vest + sunglasses) full-bleed on left half of the
 * card, three short bullet lines with orange checkmarks on the right.
 *
 * Per Figma: 3 lines (chemist line added). All Chris's own words.
 */
const lines = [
  'I started my career trying to be a chemist',
  'I do my best work in conversation, not behind the scenes',
  'I don’t set revenue goals. I focus on value and let the results follow',
];
---

<section class="cc-fun">
  <div class="cc-fun-card">
    <div class="cc-fun-photo" aria-hidden="true"></div>
    <div class="cc-fun-text">
      <h2>Just for Fun</h2>
      <div class="cc-fun-list">
        {
          lines.map((l) => (
            <div class="cc-fun-line">
              <svg
                width="18"
                height="18"
                viewBox="0 0 18 18"
                fill="none"
                stroke="currentColor"
                stroke-width="2.4"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <polyline points="3 9.5 7 13.5 15 5" />
              </svg>
              <span>{l}</span>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .cc-fun {
    padding: 80px clamp(24px, 16vw, 314px);
  }
  .cc-fun-card {
    border-radius: 25px;
    background: var(--cc-pearl);
    color: var(--cc-prune);
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    min-height: 420px;
    max-width: 1180px;
    margin: 0 auto;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.35);
  }
  .cc-fun-photo {
    background-image: url('/assets/chris-portrait-justforfun.png');
    background-size: cover;
    background-position: center 25%;
    background-color: var(--cc-pearl);
    min-height: 420px;
  }
  .cc-fun-text {
    padding: 60px;
    display: flex;
    flex-direction: column;
    gap: 28px;
    justify-content: center;
  }
  .cc-fun-text h2 {
    font-family: var(--cc-font-display);
    font-weight: 500;
    font-size: clamp(36px, 4.2vw, 56px);
    line-height: 1;
    color: var(--cc-mirinda);
    margin: 0;
  }
  .cc-fun-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .cc-fun-line {
    display: grid;
    grid-template-columns: 22px 1fr;
    align-items: start;
    gap: 14px;
    font-family: var(--cc-font-body);
    font-size: 18px;
    line-height: 1.4;
    color: var(--cc-prune);
  }
  .cc-fun-line svg {
    color: var(--cc-mirinda);
    margin-top: 3px;
  }
  @media (max-width: 900px) {
    .cc-fun {
      padding: 50px 24px;
    }
    .cc-fun-card {
      grid-template-columns: 1fr;
    }
    .cc-fun-photo {
      min-height: 280px;
      background-position: center 15%;
    }
    .cc-fun-text {
      padding: 36px;
    }
  }
</style>
