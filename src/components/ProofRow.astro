---
/**
 * ProofRow — "PROOF OF IMPACT" green eyebrow + four credential columns.
 *
 * Eyebrow is lime green (--cc-chinese) to match the Figma (Chris 2026-05-20).
 * This intentionally overrides the earlier "lime reserved for CTAs" rule.
 *
 * Verified credentials (Chris 2026-05-20):
 *   1. Founder, Value-First Team
 *   2. Creator of the Value-First methodology
 *   3. HubSpot Solutions Partner since 2023
 *   4. Host of 1,000+ LinkedIn Live Streams
 */
const items = [
  { headline: 'Founder,', sub: 'Value-First Team' },
  { headline: 'Creator of the', sub: 'Value-First methodology' },
  { headline: 'HubSpot Solutions', sub: 'Partner since 2023' },
  { headline: 'Host of 1,000+', sub: 'LinkedIn Live Streams' },
];
---

<section class="cc-proofrow">
  <div class="cc-proof-eyebrow">Proof of Impact</div>
  <div class="cc-proof-items">
    {
      items.map((it) => (
        <div class="cc-proof-item">
          <div class="cc-proof-headline">{it.headline}</div>
          <div class="cc-proof-sub">{it.sub}</div>
        </div>
      ))
    }
  </div>
</section>

<style>
  .cc-proofrow {
    position: relative;
    z-index: 2;
    padding: 20px clamp(24px, 12vw, 240px) 80px;
    display: grid;
    grid-template-columns: auto 1fr;
    align-items: start;
    gap: 60px;
  }
  .cc-proof-eyebrow {
    font-family: var(--cc-font-meta);
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    /* Lime green to match the Figma proof-row eyebrow (Chris 2026-05-20). */
    color: var(--cc-chinese);
    padding-top: 4px;
    white-space: nowrap;
  }
  .cc-proof-items {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 48px;
  }
  .cc-proof-item {
    color: var(--cc-pearl);
    font-family: var(--cc-font-body);
    font-size: 18px;
    line-height: 1.35;
  }
  .cc-proof-headline {
    font-weight: 700;
  }
  .cc-proof-sub {
    font-weight: 700;
    opacity: 0.95;
  }
  @media (max-width: 900px) {
    .cc-proofrow {
      grid-template-columns: 1fr;
      gap: 24px;
      padding: 20px 24px 60px;
    }
    .cc-proof-items {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 24px;
    }
  }
  @media (max-width: 520px) {
    .cc-proof-items {
      grid-template-columns: 1fr;
    }
  }
</style>
