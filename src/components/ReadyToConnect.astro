---
/**
 * ReadyToConnect — closing CTA. Centered headline, short body, primary CTA.
 * Copy verbatim from bundle.
 */
import { SITE } from '../lib/site';
---

<section class="cc-ready">
  <img class="cc-halo cc-ready-ring" src="/assets/ellipse-17.webp" alt="" aria-hidden="true" />
  <h2 class="cc-ready-headline">Ready to Connect?</h2>
  <p class="cc-ready-body">
    If something feels off in how your company is operating, you&rsquo;re probably right. Let&rsquo;s have a real conversation and see where you are.
  </p>
  <a class="cc-btn" href={SITE.links.bookCall} target="_blank" rel="noopener">Book a Call</a>
</section>

<style>
  .cc-ready {
    position: relative;
    padding: 60px clamp(24px, 20vw, 390px) 120px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 28px;
    text-align: center;
    /* No clip — the ring overflows the section seam with its own soft blurred
       edge instead of a hard line; html/body clip horizontally (no scrollbar). */
  }
  .cc-ready > *:not(.cc-halo) {
    position: relative;
    z-index: 1;
  }
  /* Ellipse 17 as a soft luminous glow bleeding off the upper-right (Figma
     15-readytoconnect) — blur + screen blend, not a flat grey donut. */
  .cc-ready-ring {
    position: absolute;
    right: -300px;
    top: -120px;
    width: 660px;
    height: auto;
    z-index: 0;
    opacity: 0.5;
    filter: blur(30px) saturate(1.2);
    mix-blend-mode: screen;
    /* Feather the BOTTOM edge. The ring bleeds down across the band seam (~79%
       down its height) into the opaque Footer, which would otherwise occlude the
       lower edge into a hard line. Fade to transparent before that seam. */
    -webkit-mask-image: linear-gradient(to bottom, #000 0%, #000 65%, transparent 77%);
    mask-image: linear-gradient(to bottom, #000 0%, #000 65%, transparent 77%);
    -webkit-mask-repeat: no-repeat;
    mask-repeat: no-repeat;
    pointer-events: none;
    user-select: none;
  }
  @media (max-width: 900px) { .cc-ready-ring { display: none; } }
  .cc-ready-headline {
    font-family: var(--cc-font-display);
    font-weight: 500;
    font-size: clamp(36px, 4.2vw, 64px);
    line-height: 1;
    color: var(--cc-mirinda);
    margin: 0;
  }
  .cc-ready-body {
    margin: 0;
    max-width: 640px;
    font-family: var(--cc-font-body);
    font-size: 20px;
    line-height: 1.55;
    color: var(--cc-pearl);
  }
</style>
