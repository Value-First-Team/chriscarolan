---
/**
 * SpeakingKit — two separate dark sections (no cream card):
 *   1. "Speaking Kit" — orange title + body + lime "DOWNLOAD SPEAKING KIT" CTA on left,
 *      tablet-style mockup (Speaking & Media Kit cover) on right
 *   2. "Surviving the SaaSpocalypse" — book cover on left, orange title + body + outlined
 *      "LEARN MORE" CTA on right
 *
 * Per Figma: both rows sit on the navy page background, not inside a cream card.
 * Book blurb pulled from canonical synopsis.
 */
import { SITE } from '../lib/site';
---

<section class="cc-kit">
  <img class="cc-kit-ring" src="/assets/ellipse-14.webp" alt="" aria-hidden="true" />
  <!-- Speaking Kit row -->
  <div class="cc-kit-row cc-kit-row-speaking">
    <div class="cc-kit-text">
      <h2 class="cc-kit-headline">Speaking Kit</h2>
      <p>
        Want the full overview? Download my speaking kit for my bio, topics, podcast appearances, and more.
      </p>
      <div>
        <a class="cc-btn" href={SITE.links.speakingKit} target="_blank" rel="noopener" download>Download Speaking Kit</a>
      </div>
    </div>
    <div class="cc-kit-mockup">
      <img src="/assets/speaking-media-kit.png" alt="Chris Carolan Speaking & Media Kit cover" />
    </div>
  </div>

  <!-- Book row -->
  <div class="cc-kit-row cc-kit-row-book">
    <img
      src="/assets/book-cover.png"
      alt="Surviving the SaaSpocalypse — book cover"
      class="cc-kit-book-cover"
    />
    <div class="cc-kit-text">
      <h2 class="cc-kit-headline cc-kit-book-title">
        Surviving the<br />SaaSpocalypse
      </h2>
      <p>
        Most companies are trying to layer AI onto systems that were never designed to share context. The result? Fragmented operations, and technology that can&rsquo;t deliver on its promise. Chris Carolan and the Value-First Team break down why this is happening, what comes next, and how organizations can rebuild around context, trust, and human-AI collaboration.
      </p>
      <div>
        <a class="cc-btn-outline" href={SITE.links.bookLearnMore} target="_blank" rel="noopener">
          Learn More
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .cc-kit {
    position: relative;
    padding: 80px clamp(24px, 16vw, 314px);
    display: flex;
    flex-direction: column;
    gap: 80px;
    overflow: hidden;
  }
  /* Ellipse 14 as a soft luminous glow bleeding off the lower-right (Figma
     12-speakingkit) — blur + screen blend, not a flat grey donut. */
  .cc-kit-ring {
    position: absolute;
    right: -320px;
    bottom: -260px;
    width: 700px;
    height: auto;
    z-index: 0;
    opacity: 0.5;
    filter: blur(30px) saturate(1.2);
    mix-blend-mode: screen;
    pointer-events: none;
    user-select: none;
  }
  @media (max-width: 900px) { .cc-kit-ring { display: none; } }
  .cc-kit-row {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 60px;
    align-items: center;
    max-width: 1180px;
    width: 100%;
    margin: 0 auto;
  }
  .cc-kit-row-speaking {
    grid-template-columns: 1fr 1.1fr;
  }
  .cc-kit-row-book {
    grid-template-columns: auto 1fr;
  }
  .cc-kit-text {
    display: flex;
    flex-direction: column;
    gap: 22px;
  }
  .cc-kit-headline {
    font-family: var(--cc-font-display);
    font-weight: 500;
    font-size: clamp(32px, 4.2vw, 56px);
    line-height: 1;
    color: var(--cc-mirinda);
    margin: 0;
  }
  .cc-kit-book-title {
    line-height: 1.05;
  }
  .cc-kit-text p {
    margin: 0;
    font-family: var(--cc-font-body);
    font-size: 18px;
    line-height: 1.6;
    color: var(--cc-pearl);
  }

  /* Speaking Kit tablet mockup — Figma source raster (Speaking & Media 1.png) */
  .cc-kit-mockup {
    position: relative;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .cc-kit-mockup img {
    width: 100%;
    max-width: 560px;
    height: auto;
    display: block;
    filter: drop-shadow(0 20px 40px rgba(0, 0, 0, 0.5));
  }

  .cc-kit-book-cover {
    width: 320px;
    max-width: 100%;
    height: auto;
    border-radius: 4px;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.55);
  }

  @media (max-width: 900px) {
    .cc-kit {
      padding: 50px 24px;
      gap: 60px;
    }
    .cc-kit-row-speaking,
    .cc-kit-row-book {
      grid-template-columns: 1fr;
      gap: 30px;
    }
    .cc-kit-book-cover {
      width: 220px;
      margin: 0 auto;
    }
  }
</style>
