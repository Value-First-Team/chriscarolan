        gradientTransform="translate(295.411 295.411) rotate(90) scale(295.411)"
      >
        <stop stop-color="#1C1B2D" />
        <stop offset="1" stop-color="#595697" />
      </radialGradient>
    </defs>
  </svg>
</div>

<style define:vars={{ ring2WidthPct: `${RING2_W_PCT}%`, ring3WidthPct: `${RING3_W_PCT}%` }}>
  .cc-orbits {
    position: absolute;
    pointer-events: none;
    max-width: none;
    display: block;
  }

  /* Every ring is absolutely positioned at the bottom-center of the wrapper.
     preserveAspectRatio="xMidYMax meet" + height:auto means the SVG's own
     bottom-center sits exactly at the wrapper's bottom-center, regardless of
     viewBox aspect ratio differences between rings. */
  .cc-orbits-ring {
    position: absolute;
    left: 50%;
    bottom: 0;
    transform: translateX(-50%);
    height: auto;
    display: block;
  }

  /* Ring 1 — outermost. Full wrapper width. */
  .cc-orbits-ring-1 {
    width: 100%;
  }

  /* Ring 2 — middle. Scaled proportionally to canonical Figma ratio. */
  .cc-orbits-ring-2 {
    width: var(--ring2WidthPct);
  }

  /* Ring 3 — innermost half-disc. Scaled proportionally to canonical Figma ratio. */
  .cc-orbits-ring-3 {
    width: var(--ring3WidthPct);
  }
</style>
