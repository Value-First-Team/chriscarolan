---
/**
 * DottedOrbits — concentric crisp wireframe rings behind the hero portrait.
 *
 * Name kept for stable imports. Despite the historical name, these are NOT
 * dotted, dashed, blurred, or feathered. They are 1px solid black SVG circles
 * at 20% opacity — clean 'sonar' rings that read as faint watermark lines
 * a slightly darker shade than the navy `#1C1B2D` page background.
 *
 * Source of truth: Figma "Chris Carolan - One page" — 4 concentric rings
 * with outer radii ~295, ~422, ~538, ~701 on a 1920px canvas (centered at
 * the visual center of the hero portrait). We scale that proportionally
 * across a 2400px viewBox so the rings sit comfortably behind the portrait
 * and fade out past the hero's overflow boundary.
 */
interface Props {
  size?: number;
  left?: string | number;
  top?: string | number;
  opacity?: number;
}

const { size = 2400, left, top, opacity = 1 } = Astro.props;

const toCss = (v: string | number | undefined) =>
  v === undefined ? undefined : typeof v === 'number' ? `${v}px` : v;

const styleParts = [
  toCss(left) ? `left: ${toCss(left)}` : undefined,
  toCss(top) ? `top: ${toCss(top)}` : undefined,
  `opacity: ${opacity}`,
  `width: ${size}px`,
  `height: ${size}px`,
].filter(Boolean);

const styleStr = styleParts.join('; ');

// 4 concentric rings. Radii proportional to the Figma source (295, 422, 538, 701
// against a 1920px width), scaled up to a 2400px viewBox so the centerpoint sits
// behind the portrait. Even radial intervals roughly matching the Figma render.
const rings = [369, 528, 673, 877];
---

<svg
  class="cc-orbits"
  width={size}
  height={size}
  viewBox="0 0 2400 2400"
  style={styleStr}
  aria-hidden="true"
>
  {
    rings.map((r) => (
      <circle
        cx="1200"
        cy="1200"
        r={r}
        fill="none"
        stroke="#000000"
        stroke-width="1"
        stroke-opacity="0.2"
        vector-effect="non-scaling-stroke"
      />
    ))
  }
</svg>

<style>
  .cc-orbits {
    position: absolute;
    pointer-events: none;
    max-width: none;
    width: 100%;
    height: 100%;
  }
</style>
