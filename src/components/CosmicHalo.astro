---
/**
 * CosmicHalo — large blurred radial gradient with a deep inset shadow,
 * creating a soft "planet" form in negative space.
 * Pure decoration, pointer-events: none.
 */
interface Props {
  size?: number;
  left?: string | number;
  top?: string | number;
  right?: string | number;
  bottom?: string | number;
  opacity?: number;
  flipX?: boolean;
  hideOnMobile?: boolean;
}

const {
  size = 660,
  left,
  top,
  right,
  bottom,
  opacity = 0.5,
  flipX = false,
  hideOnMobile = false,
} = Astro.props;

const toCss = (v: string | number | undefined) =>
  v === undefined ? undefined : typeof v === 'number' ? `${v}px` : v;

const styleParts = [
  `width: ${size}px`,
  `height: ${size}px`,
  `opacity: ${opacity}`,
  toCss(left) ? `left: ${toCss(left)}` : undefined,
  toCss(top) ? `top: ${toCss(top)}` : undefined,
  toCss(right) ? `right: ${toCss(right)}` : undefined,
  toCss(bottom) ? `bottom: ${toCss(bottom)}` : undefined,
  flipX ? 'transform: scaleX(-1)' : undefined,
].filter(Boolean);

const styleStr = styleParts.join('; ');
---

<div class:list={['cc-halo', hideOnMobile && 'cc-halo-desktop-only']} style={styleStr}></div>

<style>
  .cc-halo {
    position: absolute;
    border-radius: 50%;
    background: radial-gradient(circle, #1d1c31 0%, #595697 100%);
    box-shadow: inset 0px -10px 80px 20px #000;
    pointer-events: none;
  }
  @media (max-width: 768px) {
    .cc-halo-desktop-only {
      display: none;
    }
  }
</style>
