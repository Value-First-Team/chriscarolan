---
/**
 * MeetChris — large bottom-anchored cutout portrait flanked by two WIDE text
 * columns that overlay the shoulders. Portrait is sized in vw and the columns
 * in fr, so the whole section scales together responsively. Divider glow at the
 * section's bottom border (same asset as the hero).
 */
---

<section class="cc-meet">
  <h2 class="cc-meet-headline">Meet Chris</h2>

  <div class="cc-meet-body">
    <div class="cc-meet-portrait" aria-hidden="true">
      <img src="/assets/meet-portrait.webp" alt="" />
    </div>

    <div class="cc-meet-col cc-meet-col-left">
      <p>
        Hey! I&rsquo;m Chris Carolan, and I help leaders and businesses move from industrial-age operations to AI-empowered organizations. I do this with a Value-First mindset so you can activate your team&rsquo;s capabilities instead of replacing them.
      </p>
      <p>
        What makes my work different isn&rsquo;t just my understanding of HubSpot, AI, or business systems. It&rsquo;s how I think.
      </p>
    </div>

    <div class="cc-meet-col cc-meet-col-right">
      <p>
        I see patterns across domains that most people miss. I question assumptions others have stopped noticing. And I bring a kind of optimism that makes change feel possible, even when the decision in front of you feels impossible.
      </p>
      <p class="cc-meet-emphasis">Most of all, I care.</p>
      <p>
        About the people inside the system. About helping leaders make better decisions. About building companies that actually work for the humans inside them, not just the spreadsheet.
      </p>
    </div>
  </div>

  <!-- Same luminous divider as the hero, at the section's bottom border -->
  <div class="cc-meet-divider" aria-hidden="true">
    <img src="/assets/hero-divider.webp" alt="" />
  </div>
</section>

<style>
  .cc-meet {
    position: relative;
    padding: 120px clamp(24px, 10vw, 200px) 0;
    overflow: hidden;
    /* Section-level cosmic band, veiled into navy at top + bottom */
    background:
      linear-gradient(180deg, #1C1B2D 0%, rgba(28, 27, 45, 0) 35%, rgba(28, 27, 45, 0) 65%, #1C1B2D 100%),
      url('/assets/bg-cosmic-particles.jpg') center center / cover no-repeat;
  }
  .cc-meet-headline {
    position: relative;
    z-index: 3;
    font-family: var(--cc-font-display);
    font-weight: 500;
    font-size: clamp(36px, 4.2vw, 64px);
    line-height: 1;
    color: var(--cc-mirinda);
    margin: 0 0 40px;
    text-align: center;
  }

  /* Two wide text columns; the center is reserved (gap) for the face, and the
     large portrait overlaps the inner edges (shoulders). */
  .cc-meet-body {
    position: relative;
    z-index: 1;
    max-width: 1280px;
    margin: 0 auto;
    min-height: clamp(440px, 48vw, 700px);
    display: grid;
    grid-template-columns: 1fr 1fr;
    column-gap: clamp(40px, 26vw, 440px);
    align-items: start;
  }
  .cc-meet-col {
    position: relative;
    z-index: 2; /* text overlays the portrait shoulders */
    font-family: var(--cc-font-body);
    font-size: clamp(15px, 1.15vw, 18px);
    line-height: 1.6;
    color: var(--cc-pearl);
    display: flex;
    flex-direction: column;
    gap: 18px;
  }
  .cc-meet-col-right {
    padding-top: 60px;
  }
  .cc-meet-col p {
    margin: 0;
  }
  .cc-meet-emphasis {
    font-weight: 500;
  }

  /* Cutout portrait — sized in vw (scales with the section), anchored bottom-center */
  .cc-meet-portrait {
    position: absolute;
    left: 50%;
    bottom: 0;
    transform: translateX(-50%);
    width: clamp(360px, 44vw, 640px);
    z-index: 1;
    pointer-events: none;
  }
  .cc-meet-portrait img {
    width: 100%;
    height: auto;
    display: block;
    /* whisper of bottom fade for the photo's hard lower crop */
    -webkit-mask-image: linear-gradient(to bottom, #000 88%, transparent 100%);
    mask-image: linear-gradient(to bottom, #000 88%, transparent 100%);
    -webkit-mask-repeat: no-repeat;
    mask-repeat: no-repeat;
    -webkit-mask-size: 100% 100%;
    mask-size: 100% 100%;
  }

  /* Luminous divider at the section's bottom border (same asset as the hero) */
  .cc-meet-divider {
    position: relative;
    z-index: 3;
    width: 100vw;
    left: 50%;
    transform: translateX(-50%);
    margin-top: 16px;
    pointer-events: none;
  }
  .cc-meet-divider img {
    width: 100%;
    height: auto;
    display: block;
  }

  @media (max-width: 900px) {
    .cc-meet {
      padding: 60px 24px 0;
    }
    .cc-meet-body {
      grid-template-columns: 1fr;
      column-gap: 0;
      gap: 24px;
      min-height: 0;
    }
    .cc-meet-portrait {
      position: relative;
      left: auto;
      bottom: auto;
      transform: none;
      width: 320px;
      margin: 24px auto 0;
    }
    .cc-meet-col-right {
      padding-top: 0;
    }
  }
</style>
