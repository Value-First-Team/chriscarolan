---
/**
 * HowICanHelp — three-step path to working with Chris. Numbered titles + body + CTA.
 * Step copy verbatim from bundle (already in Chris's voice).
 */
import { SITE } from '../lib/site';

const steps = [
  {
    n: '1',
    title: 'Start with a\nreal conversation',
    body: 'No pitch deck. No overproduced demo. Just an honest conversation about what feels off, what’s not working, and what may need to change.',
  },
  {
    n: '2',
    title: 'See what’s possible',
    body: 'In a live working session, I’ll help you build something real so the difference becomes obvious fast.',
  },
  {
    n: '3',
    title: 'Build the\nright path forward',
    body: 'From coaching to deep transformation work, the goal is always the same: help your organization work better, think better, and build capability and value that lasts.',
  },
];
---

<section class="cc-how">
  <!-- Figma ring (Ellipse 15) bleeding off the right — replaces the solid CosmicHalo disc -->
  <img class="cc-how-ring" src="/assets/ellipse-15.webp" alt="" aria-hidden="true" />
  <div class="cc-how-inner">
    <h2 class="cc-how-headline">How I Can Help</h2>
    <div class="cc-how-grid">
      {
        steps.map((s) => (
          <div class="cc-how-step">
            <div class="cc-how-step-n">{s.n}</div>
            <div class="cc-how-step-title">{s.title}</div>
            <div class="cc-how-step-body">{s.body}</div>
          </div>
        ))
      }
    </div>
    <a class="cc-btn" href={SITE.links.bookCall} target="_blank" rel="noopener">Work With Me</a>
  </div>
</section>

<style>
  .cc-how {
    position: relative;
    padding: 60px clamp(24px, 16vw, 314px);
    overflow: hidden;
  }
  /* Figma ring decoration — bleeds off the right edge behind the card */
  .cc-how-ring {
    position: absolute;
    right: -300px;
    top: -60px;
    width: 560px;
    height: auto;
    z-index: 0;
    pointer-events: none;
    user-select: none;
  }
  @media (max-width: 900px) {
    .cc-how-ring { display: none; }
  }
  .cc-how-inner {
    position: relative;
    z-index: 1;
    border-radius: 25px;
    background: var(--cc-pearl);
    color: var(--cc-prune);
    padding: clamp(40px, 5vw, 75px);
    display: flex;
    flex-direction: column;
    gap: 50px;
    align-items: center;
    text-align: left;
    max-width: 1080px;
    margin: 0 auto;
    margin-right: clamp(40px, 8vw, 140px);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.35);
  }
  .cc-how-headline {
    align-self: stretch;
    font-family: var(--cc-font-display);
    font-weight: 500;
    font-size: clamp(36px, 4.2vw, 56px);
    line-height: 1;
    color: var(--cc-mirinda);
    margin: 0;
  }
  .cc-how-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 50px;
    align-self: stretch;
  }
  .cc-how-step {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .cc-how-step-n {
    font-family: var(--cc-font-display);
    font-weight: 500;
    font-size: 28px;
    line-height: 1;
    color: var(--cc-mirinda);
  }
  .cc-how-step-title {
    font-family: var(--cc-font-body);
    font-weight: 700;
    font-size: 22px;
    line-height: 1.15;
    color: var(--cc-prune);
    white-space: pre-line;
  }
  .cc-how-step-body {
    font-family: var(--cc-font-body);
    font-size: 16px;
    line-height: 1.55;
    color: var(--cc-prune);
    opacity: 0.9;
  }
  @media (max-width: 900px) {
    .cc-how-inner {
      margin-right: auto;
    }
    .cc-how-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }
</style>
