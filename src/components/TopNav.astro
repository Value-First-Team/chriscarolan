---
/**
 * TopNav — brand left, single outlined "Book a Call" CTA right.
 * No multi-link nav. One-page scroll site.
 */
import CCLogo from './CCLogo.astro';
import { SITE } from '../lib/site';
---

<header class="cc-topnav">
  <a href="/" class="cc-topnav-brand" aria-label="Chris Carolan — home">
    <CCLogo height={50} color="cream" />
  </a>
  <a class="cc-btn-outline" href={SITE.links.bookCall} target="_blank" rel="noopener">
    Book a Call
  </a>
</header>

<style>
  .cc-topnav {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    z-index: 10;
    width: 100%;
    height: 98px;
    background: transparent;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px clamp(24px, 20vw, 390px);
    pointer-events: none;
  }
  .cc-topnav > * {
    pointer-events: auto;
  }
  .cc-topnav-brand {
    display: flex;
    align-items: center;
    filter: drop-shadow(0 2px 8px rgba(28, 27, 45, 0.6));
  }
  @media (max-width: 600px) {
    .cc-topnav {
      position: relative;
      height: auto;
      padding: 20px 24px;
      gap: 16px;
    }
  }
</style>
