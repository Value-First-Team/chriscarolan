---
/**
 * SpeakingMedia — section headline + 5 IconOrb cards in 3+2 grid + "BOOK TO SPEAK" CTA.
 *
 * Per Figma: all five signature talks share the same orange-glow card treatment,
 * each with a unique IconOrb at the top. Top row: 3 cards. Bottom row: 2 cards
 * centered. The CTA links to Chris's HubSpot Meetings public-speaking booking page
 * (wired from SITE.links.bookToSpeak — distinct from the speaking-kit mailto).
 */
import IconOrb from './IconOrb.astro';
import { SITE } from '../lib/site';

const talks = [
  {
    title: "Don't Replace Your\nPeople, Activate Them",
    body: 'Why AI should unlock human capability, not erase it.',
    icon: 'people',
  },
  {
    title: 'From the Industrial\nAge to the AI Era',
    body: 'How to rethink the way your company operates before you add more tools.',
    icon: 'grid',
  },
  {
    title: 'Value Over Activity',
    body: 'Why most companies are measuring the wrong things and what to do instead.',
    icon: 'scale',
  },
  {
    title: 'Transformation,\nNot Optimization',
    body: 'Stop improving broken systems. Build the right one.',
    icon: 'route',
  },
  {
    title: 'The 5-Layer Model\nto Become AI-Native',
    body: 'What it takes to rebuild your company for the AI era.',
    icon: 'layers',
  },
];
---

<section class="cc-speak">
  <div class="cc-speak-inner">
    <div class="cc-speak-heading">
      <h2 class="cc-speak-headline">Speaking &amp; Media</h2>
      <div class="cc-speak-sub">
        I speak to leaders and teams who know the old way of operating no longer fits and want a more human, practical path into the AI era.
      </div>
    </div>

    <div class="cc-speak-grid">
      {
        talks.map((t) => (
          <div class="cc-speak-card">
            <IconOrb size={56}>
              {t.icon === 'people' && (
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="9" cy="8" r="3.2" />
                  <circle cx="17" cy="10" r="2.4" />
                  <path d="M3 19c0-3 3-5 6-5s6 2 6 5" />
                  <path d="M14 19c0-2 2-3.5 4-3.5s3.5 1.5 3.5 3.5" />
                </svg>
              )}
              {t.icon === 'grid' && (
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="3" width="7" height="7" />
                  <rect x="14" y="3" width="7" height="7" />
                  <rect x="14" y="14" width="7" height="7" />
                  <rect x="3" y="14" width="7" height="7" />
                </svg>
              )}
              {t.icon === 'scale' && (
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 3v18" />
                  <path d="M5 7h14" />
                  <path d="M5 7l-3 6a4 4 0 008 0L7 7" />
                  <path d="M19 7l-3 6a4 4 0 008 0l-3-6" transform="translate(-2 0)" />
                </svg>
              )}
              {t.icon === 'route' && (
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="4" y1="4" x2="8" y2="8" />
                  <line x1="8" y1="4" x2="4" y2="8" />
                  <circle cx="6" cy="14" r="2" />
                  <path d="M8 14c4 0 4 -4 8 -4" />
                  <polyline points="14 6 18 6 18 10" />
                  <line x1="16" y1="16" x2="20" y2="20" />
                  <line x1="20" y1="16" x2="16" y2="20" />
                </svg>
              )}
              {t.icon === 'layers' && (
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="12 2 22 8.5 12 15 2 8.5 12 2" />
                  <polyline points="2 15.5 12 22 22 15.5" />
                  <polyline points="2 12 12 18.5 22 12" />
                </svg>
              )}
            </IconOrb>
            <div class="cc-speak-card-title">{t.title}</div>
            <div class="cc-speak-card-body">{t.body}</div>
          </div>
        ))
      }
    </div>

    <a class="cc-btn" href={SITE.links.bookToSpeak} target="_blank" rel="noopener">
      Book to Speak
    </a>
  </div>
</section>

<style>
  .cc-speak {
    padding: 80px clamp(24px, 16vw, 314px);
  }
  .cc-speak-inner {
    display: flex;
    flex-direction: column;
    gap: 50px;
    align-items: center;
    max-width: 1180px;
    margin: 0 auto;
  }
  .cc-speak-heading {
    display: flex;
    flex-direction: column;
    gap: 22px;
    align-items: center;
    max-width: 760px;
    text-align: center;
  }
  .cc-speak-headline {
    font-family: var(--cc-font-display);
    font-weight: 500;
    font-size: clamp(36px, 4.2vw, 64px);
    line-height: 1;
    color: var(--cc-mirinda);
    margin: 0;
  }
  .cc-speak-sub {
    font-family: var(--cc-font-body);
    font-size: 18px;
    line-height: 1.55;
    color: var(--cc-pearl);
    opacity: 0.95;
  }

  /* 3 + 2 grid. The 5th card sits in column 2 of the second row visually.
     Use a 6-col grid; each card spans 2; last two are offset to center. */
  .cc-speak-grid {
    width: 100%;
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 28px;
  }
  .cc-speak-card {
    grid-column: span 2;
    border-radius: 16px;
    border: 0.5px solid var(--cc-mirinda-deep);
    background:
      radial-gradient(ellipse at 50% 0%, rgba(248, 95, 54, 0.22) 0%, rgba(248, 95, 54, 0) 70%),
      #1D1C31;
    padding: 28px 28px 32px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    box-shadow: 0 0 40px rgba(0, 0, 0, 0.4);
  }
  /* Center the last two cards: card 4 starts at col 2, card 5 at col 4 */
  .cc-speak-card:nth-child(4) {
    grid-column: 2 / span 2;
  }
  .cc-speak-card:nth-child(5) {
    grid-column: 4 / span 2;
  }
  .cc-speak-card-title {
    font-family: var(--cc-font-body);
    font-weight: 700;
    font-size: 22px;
    line-height: 1.15;
    color: var(--cc-mirinda);
    white-space: pre-line;
    margin-top: 6px;
  }
  .cc-speak-card-body {
    font-family: var(--cc-font-body);
    font-size: 16px;
    line-height: 1.5;
    color: var(--cc-pearl);
    opacity: 0.92;
  }

  @media (max-width: 1100px) {
    .cc-speak-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .cc-speak-card,
    .cc-speak-card:nth-child(4),
    .cc-speak-card:nth-child(5) {
      grid-column: span 1;
    }
  }
  @media (max-width: 600px) {
    .cc-speak {
      padding: 60px 24px;
    }
    .cc-speak-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
