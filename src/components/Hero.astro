---
/**
 * Hero — orange Kameron headline overlaying a centered portrait of Chris,
 * layered against concentric luminous half-donut ring tubes (per Figma
 * "Chris Carolan - One page" source of truth).
 *
 * The hero background is FLAT navy (var(--cc-prune)). The atmospheric
 * luminosity comes from the radial gradients baked into each ring tube —
 * no cosmic-particle JPG, no separate halo. The rings ARE the atmosphere.
 *
 * Z-stack (back to front):
 *   0. Flat navy hero base
 *   1. Concentric luminous half-donut ring tubes (DottedOrbits)
 *   2. Chris portrait, alpha-masked at edges so it fades into the navy page
 *   3. Headline + subtitle + CTA + byline (centered, overlays portrait)
 */
import DottedOrbits from './DottedOrbits.astro';
import { SITE } from '../lib/site';
---

<section class="cc-hero">
  <!-- Concentric luminous half-donut ring tubes — arc UP from the baseline -->
  <div class="cc-hero-orbits-wrap" aria-hidden="true">
    <DottedOrbits size={2400} />
  </div>

  <!-- Portrait — sits BEHIND the headline, alpha-masked at edges -->
  <div class="cc-hero-portrait" aria-hidden="true">
    <img src="/assets/chris-portrait-hero.png" alt="" />
  </div>

  <!-- Headline stack — orange Kameron over the portrait -->
  <div class="cc-hero-stack">
    <h1 class="cc-hero-headline">
      Don&rsquo;t Replace Your<br />
      People, Activate Them
    </h1>
    <div class="cc-hero-subtitle">{SITE.tagline}</div>
    <div class="cc-hero-cta">
      <a class="cc-btn" href={SITE.links.bookCall} target="_blank" rel="noopener">Book a Call</a>
    </div>
    <div class="cc-hero-byline">
      Chris Carolan &nbsp;|&nbsp; Business Transformation Advisor for the AI Era
    </div>
  </div>
</section>

<style>
  .cc-hero {
    position: relative;
    width: 100%;
    max-width: 100vw;
    min-height: 760px;
    overflow: hidden;
    padding: 30px clamp(24px, 12vw, 240px) 70px;
    isolation: isolate;
    /* Flat navy base — rings provide all atmospheric luminosity */
    background: var(--cc-prune, #1C1B2D);
  }

  /* Concentric luminous half-ring SVGs — anchored at the hero baseline.
     Three canonical Figma SVGs (Ring 1: 1920x705, Ring 2: 1076x538, Ring 3:
     591x296 half-disc) stack with shared bottom-center. Wrapper aspect ratio
     matches Ring 1 (1920:705 ~ 2.723:1) so Ring 1 fills the box exactly. */
  .cc-hero-orbits-wrap {
    position: absolute;
    left: 50%;
    bottom: 70px;
    transform: translateX(-50%);
    width: min(1920px, 140vw);
    aspect-ratio: 1920 / 705;
    max-width: none;
    pointer-events: none;
    z-index: 1;
  }
  .cc-hero-orbits-wrap :global(.cc-orbits) {
    position: absolute;
    left: 0;
    bottom: 0;
    top: auto;
    width: 100%;
    height: 100%;
  }

  /* Portrait — centered, soft radial alpha mask on the img itself so the
     bitmap edges fade into navy with no rectangular crop visible. */
  .cc-hero-portrait {
    position: absolute;
    left: 50%;
    top: -20px;
    transform: translateX(-50%);
    width: 480px;
    max-width: 70vw;
    height: 600px;
    pointer-events: none;
    z-index: 2;
  }
  .cc-hero-portrait img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 15%;
    display: block;
    -webkit-mask-image: radial-gradient(
      ellipse at center,
      #000 55%,
      rgba(0, 0, 0, 0.6) 78%,
      rgba(0, 0, 0, 0) 95%
    );
    mask-image: radial-gradient(
      ellipse at center,
      #000 55%,
      rgba(0, 0, 0, 0.6) 78%,
      rgba(0, 0, 0, 0) 95%
    );
    -webkit-mask-repeat: no-repeat;
    mask-repeat: no-repeat;
    -webkit-mask-size: 100% 100%;
    mask-size: 100% 100%;
  }

  /* Headline stack — overlays the portrait */
  .cc-hero-stack {
    position: relative;
    z-index: 3;
    padding-top: 280px;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 18px;
    align-items: center;
  }
  /* Class selector beats the global `h1 { color: ... }` rule */
  .cc-hero-headline,
  h1.cc-hero-headline {
    font-family: var(--cc-font-display);
    font-weight: 500;
    font-size: clamp(44px, 6vw, 88px);
    line-height: 1.02;
    color: var(--cc-mirinda);
    margin: 0;
    max-width: 1100px;
    letter-spacing: -0.01em;
    text-shadow: 0 4px 24px rgba(28, 27, 45, 0.7);
  }
  .cc-hero-subtitle {
    font-family: var(--cc-font-body);
    font-size: clamp(15px, 1.2vw, 18px);
    color: var(--cc-pearl);
    opacity: 0.95;
    max-width: 640px;
    font-weight: 500;
  }
  .cc-hero-cta {
    margin-top: 4px;
  }
  .cc-hero-byline {
    margin-top: 24px;
    font-family: var(--cc-font-body);
    font-size: 14px;
    color: var(--cc-pearl-soft);
    opacity: 0.75;
    letter-spacing: 0.01em;
  }

  @media (max-width: 900px) {
    .cc-hero {
      min-height: auto;
      padding: 20px 24px 60px;
    }
    .cc-hero-orbits-wrap {
      width: min(1600px, 180vw);
      aspect-ratio: 1920 / 705;
      bottom: 40px;
    }
    .cc-hero-portrait {
      width: 320px;
      height: 400px;
      top: 0;
    }
    .cc-hero-stack {
      padding-top: 230px;
    }
    .cc-hero-headline,
    h1.cc-hero-headline {
      font-size: clamp(36px, 9vw, 56px);
    }
  }
</style>
