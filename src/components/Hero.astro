---
/**
 * Hero — page H1 + subtitle + CTA + browser-title strip.
 * Cosmic halo + dotted orbits behind a centered portrait.
 */
import CosmicHalo from './CosmicHalo.astro';
import DottedOrbits from './DottedOrbits.astro';
import { SITE } from '../lib/site';
---

<section class="cc-hero">
  <!-- Ambient atmosphere -->
  <DottedOrbits left="-188px" top="-443px" />
  <CosmicHalo size={664} left="calc(50% + 100px)" top={-200} flipX={true} hideOnMobile={true} />

  <!-- Centered portrait with masked gradient column -->
  <div class="cc-hero-portrait" aria-hidden="true">
    <div class="cc-hero-portrait-veil"></div>
    <img src="/assets/chris-portrait-hero.png" alt="" />
  </div>

  <!-- Headline stack -->
  <div class="cc-hero-stack">
    <h1>Don&rsquo;t Replace Your People, Activate Them</h1>
    <div class="cc-hero-subtitle">{SITE.tagline}</div>
    <div class="cc-hero-cta">
      <a class="cc-btn" href={SITE.links.bookCall} target="_blank" rel="noopener">Book a Call</a>
    </div>
    <div class="cc-hero-byline">
      Chris Carolan &nbsp;|&nbsp; Business Transformation Advisor for the AI Era
    </div>
  </div>
</section>

<style>
  .cc-hero {
    position: relative;
    width: 100%;
    min-height: 760px;
    overflow: hidden;
    padding: 60px clamp(24px, 20vw, 390px) 0;
  }

  .cc-hero-portrait {
    position: absolute;
    left: 50%;
    top: -6px;
    transform: translateX(-50%);
    width: 510px;
    max-width: 70vw;
    height: 532px;
    overflow: hidden;
    pointer-events: none;
  }
  .cc-hero-portrait-veil {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      #d9d9d9 35%,
      rgba(115, 115, 115, 0.2) 70%,
      rgba(115, 115, 115, 0) 100%
    );
  }
  .cc-hero-portrait img {
    position: absolute;
    left: 13px;
    top: 0;
    width: 484px;
    max-width: 100%;
    height: 603px;
    object-fit: cover;
  }

  .cc-hero-stack {
    position: relative;
    z-index: 2;
    padding-top: 280px;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 22px;
    align-items: center;
  }
  .cc-hero-stack h1 {
    font-family: var(--cc-font-display);
    font-weight: 500;
    font-size: clamp(40px, 6.2vw, 96px);
    line-height: 1;
    color: var(--cc-pearl);
    margin: 0;
    max-width: 1140px;
  }
  .cc-hero-subtitle {
    font-family: var(--cc-font-body);
    font-size: clamp(18px, 1.8vw, 32px);
    color: var(--cc-pearl-soft);
    opacity: 0.9;
  }
  .cc-hero-cta {
    margin-top: 18px;
  }
  .cc-hero-byline {
    margin-top: 32px;
    font-family: var(--cc-font-body);
    font-size: 16px;
    color: var(--cc-pearl-soft);
    opacity: 0.85;
  }

  @media (max-width: 768px) {
    .cc-hero {
      min-height: auto;
      padding: 30px 24px 0;
    }
    .cc-hero-portrait {
      width: 320px;
      height: 360px;
    }
    .cc-hero-portrait img {
      width: 320px;
      height: 400px;
    }
    .cc-hero-stack {
      padding-top: 220px;
    }
  }
</style>
