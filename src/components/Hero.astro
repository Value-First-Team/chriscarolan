---
/**
 * Hero — orange Kameron headline overlaying a centered portrait of Chris,
 * layered against the Figma ring backdrop.
 *
 * The rings are now the EXACT Figma export (baked WebP, /assets/hero-rings.webp)
 * rather than the CSS-generated half-donut tubes — the soft concentric arcs and
 * their depth/transparency carry over pixel-faithfully. See
 * design/figma/ring-composite-preview.png for the reference composite.
 *
 * Z-stack (back to front):
 *   0. Flat navy hero base (--cc-prune)
 *   1. Ring backdrop image — soft concentric half-arcs, full-bleed
 *   2. Chris portrait, masked so the torso dissolves into the navy
 *   3. Headline + subtitle + CTA + byline (centered, overlays portrait)
 */
import { SITE } from '../lib/site';
---

<section class="cc-hero">
  <!-- Ring backdrop — exact Figma export, full-bleed; arcs rise from the baseline -->
  <div class="cc-hero-rings" aria-hidden="true">
    <img src="/assets/hero-rings.webp" alt="" />
  </div>

  <!-- Portrait — sits BEHIND the headline. Fade is baked into the PNG alpha
       (exact Figma "Mask group" export), so no CSS mask is applied. -->
  <div class="cc-hero-portrait" aria-hidden="true">
    <img src="/assets/hero-portrait.png" alt="" />
  </div>

  <!-- Headline stack — orange Kameron over the portrait -->
  <div class="cc-hero-stack">
    <h1 class="cc-hero-headline">
      Don&rsquo;t Replace Your<br />
      People, Activate Them
    </h1>
    <div class="cc-hero-subtitle">{SITE.tagline}</div>
    <div class="cc-hero-cta">
      <a class="cc-btn" href={SITE.links.bookCall} target="_blank" rel="noopener">Book a Call</a>
    </div>
    <div class="cc-hero-byline">
      Chris Carolan &nbsp;|&nbsp; Business Transformation Advisor for the AI Era
    </div>
    <!-- Luminous divider at the hero's bottom edge — masks the section end so it
         doesn't read as an abrupt black line; byline sits tight above it -->
    <div class="cc-hero-divider" aria-hidden="true">
      <img src="/assets/hero-divider.webp" alt="" />
    </div>
  </div>
</section>

<style>
  .cc-hero {
    position: relative;
    width: 100%;
    max-width: 100vw;
    min-height: 680px;
    overflow: hidden;
    padding: 30px clamp(24px, 12vw, 240px) 0;
    isolation: isolate;
    /* Flat navy base — the ring backdrop image provides all atmosphere */
    background: var(--cc-prune, #1C1B2D);
  }

  /* Ring backdrop — full-bleed (edge to edge), anchored at the hero top.
     Image aspect ~2.72:1; the arcs occupy the upper hero and their radiation
     center sits at the image's bottom edge. */
  .cc-hero-rings {
    position: absolute;
    left: 0;
    top: 0;
    width: 100%;
    z-index: 1;
    pointer-events: none;
  }
  .cc-hero-rings img {
    width: 100%;
    height: auto;
    display: block;
    /* Fade the ring backdrop's bottom into the navy so the section doesn't end
       on a hard ring edge (no abrupt "black line" at the seam). */
    -webkit-mask-image: linear-gradient(to bottom, #000 72%, transparent 100%);
    mask-image: linear-gradient(to bottom, #000 72%, transparent 100%);
    -webkit-mask-repeat: no-repeat;
    mask-repeat: no-repeat;
  }

  /* Portrait — centered; soft mask keeps the head/face clean and dissolves the
     torso + shoulders gradually into the navy (no rectangular crop, no hard cutoff). */
  .cc-hero-portrait {
    position: absolute;
    left: 50%;
    top: 14px;
    transform: translateX(-50%);
    width: 560px;
    max-width: 74vw;
    pointer-events: none;
    z-index: 2;
  }
  .cc-hero-portrait img {
    width: 100%;
    height: auto;
    display: block;
    /* No CSS mask — the soft fade is baked into the PNG's alpha channel. */
  }

  /* Headline stack — overlays the portrait */
  .cc-hero-stack {
    position: relative;
    z-index: 3;
    padding-top: 300px;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 18px;
    align-items: center;
  }
  .cc-hero-headline,
  h1.cc-hero-headline {
    font-family: var(--cc-font-display);
    font-weight: 500;
    font-size: clamp(44px, 6vw, 88px);
    line-height: 1.02;
    color: var(--cc-mirinda);
    margin: 0;
    max-width: 1100px;
    letter-spacing: -0.01em;
    text-shadow: 0 4px 24px rgba(28, 27, 45, 0.7);
  }
  .cc-hero-subtitle {
    font-family: var(--cc-font-body);
    font-size: clamp(15px, 1.2vw, 18px);
    color: var(--cc-pearl);
    opacity: 0.95;
    max-width: 640px;
    font-weight: 500;
  }
  .cc-hero-cta {
    margin-top: 4px;
  }
  /* Full-bleed luminous divider at the hero's bottom edge */
  .cc-hero-divider {
    position: relative;
    width: 100vw;
    left: 50%;
    transform: translateX(-50%);
    margin: -6px 0 0; /* tight under the byline; sits at the section end */
    pointer-events: none;
  }
  .cc-hero-divider img {
    width: 100%;
    height: auto;
    display: block;
  }
  .cc-hero-byline {
    margin-top: 14px;
    font-family: var(--cc-font-body);
    font-size: 17px;
    color: var(--cc-pearl-soft);
    opacity: 0.85;
    letter-spacing: 0.01em;
  }

  @media (max-width: 900px) {
    .cc-hero {
      min-height: auto;
      padding: 20px 24px 60px;
    }
    .cc-hero-portrait {
      width: 360px;
      top: 4px;
    }
    .cc-hero-stack {
      padding-top: 250px;
    }
    .cc-hero-headline,
    h1.cc-hero-headline {
      font-size: clamp(36px, 9vw, 56px);
    }
  }
</style>
