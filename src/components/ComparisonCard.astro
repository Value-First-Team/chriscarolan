---
/**
 * ComparisonCard — Chris vs Others.
 *
 * Single dark glow shell, two columns inside (no inner panel on the Chris side).
 * Chris bullets prefixed with orange checkmarks; Others bullets prefixed with X marks.
 */
const chris = [
  'Helps you build a company that actually works with AI',
  'Focuses on the operating model underneath everything',
  'Helps you decide what needs to change first',
  'Rebuilds how systems, data, and teams connect',
  'Focuses on value, not activity',
];

const others = [
  'Help you adopt AI',
  'Focus on tools and workflows',
  'Optimize what already exists',
  'Implement platforms in isolation',
  'Measure activity and performance',
];
---

<section class="cc-cmp">
  <div class="cc-cmp-shell">
    <div class="cc-cmp-col cc-cmp-col-chris">
      <h3>Chris</h3>
      {
        chris.map((p) => (
          <div class="cc-cmp-bullet">
            <svg
              class="cc-cmp-check"
              width="18"
              height="18"
              viewBox="0 0 18 18"
              fill="none"
              stroke="currentColor"
              stroke-width="2.4"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <polyline points="3 9.5 7 13.5 15 5" />
            </svg>
            <span>{p}</span>
          </div>
        ))
      }
    </div>
    <div class="cc-cmp-col cc-cmp-col-others">
      <h3>Others</h3>
      {
        others.map((p) => (
          <div class="cc-cmp-bullet">
            <svg
              class="cc-cmp-x"
              width="18"
              height="18"
              viewBox="0 0 18 18"
              fill="none"
              stroke="currentColor"
              stroke-width="2.4"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <line x1="4" y1="4" x2="14" y2="14" />
              <line x1="14" y1="4" x2="4" y2="14" />
            </svg>
            <span>{p}</span>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .cc-cmp {
    padding: 20px clamp(24px, 16vw, 314px) 80px;
  }
  .cc-cmp-shell {
    border-radius: 25px;
    border: 0.5px solid var(--cc-mirinda-deep);
    box-shadow: 0 0 80px 0 #171625;
    padding: clamp(40px, 5vw, 75px) clamp(40px, 6vw, 90px);
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 60px;
    background:
      radial-gradient(ellipse at 50% 0%, rgba(248, 95, 54, 0.04) 0%, rgba(248, 95, 54, 0) 70%),
      #1C1B2D;
  }
  .cc-cmp-col {
    display: flex;
    flex-direction: column;
    gap: 18px;
  }
  .cc-cmp-col h3 {
    font-family: var(--cc-font-display);
    font-weight: 500;
    font-size: 36px;
    line-height: 1.07;
    color: var(--cc-mirinda);
    margin: 0 0 12px;
  }
  .cc-cmp-col-others h3 {
    color: var(--cc-pearl);
    font-family: var(--cc-font-body);
    font-weight: 700;
    font-size: 28px;
  }
  .cc-cmp-bullet {
    display: grid;
    grid-template-columns: 22px 1fr;
    align-items: start;
    gap: 14px;
    font-family: var(--cc-font-body);
    font-size: 17px;
    line-height: 1.45;
    color: var(--cc-pearl);
  }
  .cc-cmp-check {
    color: var(--cc-mirinda);
    margin-top: 3px;
  }
  .cc-cmp-x {
    color: var(--cc-pearl);
    opacity: 0.75;
    margin-top: 3px;
  }
  @media (max-width: 900px) {
    .cc-cmp-shell {
      grid-template-columns: 1fr;
      gap: 36px;
      padding: 36px;
    }
  }
</style>
