---
/**
 * InTheMedia — cream overlay card on the LEFT atop a wide dark VFT-website screenshot
 * card on the RIGHT, with "WATCH & LISTEN" CTA.
 */
import { SITE } from '../lib/site';
---

<section class="cc-itm">
  <img class="cc-itm-ring" src="/assets/ellipse-15.webp" alt="" aria-hidden="true" />
  <div class="cc-itm-frame">
    <div class="cc-itm-photo" aria-hidden="true"></div>
    <div class="cc-itm-card">
      <img
        src="/assets/value-first-team-logo.png"
        alt="Value-First Team"
        class="cc-itm-logo"
      />
      <h2 class="cc-itm-headline">In the Media</h2>
      <p>
        I host and join conversations across podcasts and platforms about what&rsquo;s changing in business in real-time.
      </p>
      <p>
        Through the <strong>Value-First Media Network</strong>, I share live shows and daily insights on AI, technology, leadership, culture, and how companies can adapt to a changing landscape.
      </p>
      <div class="cc-itm-cta">
        <a class="cc-btn" href={SITE.links.shows} target="_blank" rel="noopener">
          Watch &amp; Listen
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .cc-itm {
    position: relative;
    padding: 60px clamp(24px, 16vw, 314px);
    /* No clip — the ring overflows the section seam with its own soft blurred
       edge instead of a hard line; html/body clip horizontally (no scrollbar). */
  }
  /* Ellipse 15 as a soft luminous glow bleeding off the lower-left (Figma
     09-inthemedia) — blur + screen blend, not a flat grey donut. */
  .cc-itm-ring {
    position: absolute;
    left: -300px;
    bottom: -200px;
    width: 620px;
    height: auto;
    z-index: 0;
    opacity: 0.5;
    filter: blur(30px) saturate(1.2);
    mix-blend-mode: screen;
    pointer-events: none;
    user-select: none;
  }
  @media (max-width: 900px) { .cc-itm-ring { display: none; } }
  .cc-itm-frame {
    position: relative;
    z-index: 1;
    max-width: 1318px;
    margin: 0 auto;
    min-height: 580px;
  }
  .cc-itm-photo {
    position: absolute;
    right: 0;
    top: 0;
    width: 75%;
    height: 580px;
    border-radius: 25px;
    background-image: url('/assets/in-the-media-bg.png');
    background-size: cover;
    background-position: left center;
    background-color: #0A0A0A;
  }
  .cc-itm-card {
    position: absolute;
    left: 0;
    top: 60px;
    width: 46%;
    min-width: 360px;
    border-radius: 25px;
    background: var(--cc-pearl);
    color: var(--cc-prune);
    padding: 50px;
    display: flex;
    flex-direction: column;
    gap: 18px;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.4);
  }
  .cc-itm-logo {
    width: 64px;
    height: auto;
    margin-bottom: 4px;
  }
  .cc-itm-headline {
    font-family: var(--cc-font-display);
    font-weight: 500;
    font-size: clamp(36px, 4vw, 56px);
    line-height: 1;
    color: var(--cc-mirinda);
    margin: 0 0 4px;
  }
  .cc-itm-card p {
    margin: 0;
    font-family: var(--cc-font-body);
    font-size: 18px;
    line-height: 1.55;
    color: var(--cc-prune);
  }
  .cc-itm-card p strong {
    font-weight: 700;
  }
  .cc-itm-cta {
    margin-top: 10px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  @media (max-width: 900px) {
    .cc-itm {
      padding: 40px 24px;
    }
    .cc-itm-frame {
      min-height: 0;
    }
    .cc-itm-photo {
      position: relative;
      width: 100%;
      height: 240px;
      margin-bottom: -100px;
    }
    .cc-itm-card {
      position: relative;
      top: 0;
      width: 100%;
      min-width: 0;
      padding: 30px;
    }
  }
</style>
