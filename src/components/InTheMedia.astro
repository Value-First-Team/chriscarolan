---
/**
 * InTheMedia — overlay text card on a wide photo, with Watch & Listen CTA.
 * Body copy from bundle (about hosting/joining conversations + Value-First Media Network).
 */
import { SITE } from '../lib/site';
---

<section class="cc-itm">
  <div class="cc-itm-frame">
    <div class="cc-itm-photo" aria-hidden="true"></div>
    <div class="cc-itm-card">
      <img
        src="/assets/value-first-team-logo.png"
        alt="Value-First Team"
        class="cc-itm-logo"
      />
      <h2 class="cc-itm-headline">In the Media</h2>
      <p>
        I host and join conversations across podcasts and platforms about what&rsquo;s changing in business in real-time.
      </p>
      <p>
        Through the Value-First Media Network, I share live shows and daily insights on AI, technology, leadership, culture, and how companies can adapt to a changing landscape.
      </p>
      <div class="cc-itm-cta">
        <a class="cc-btn" href={SITE.links.shows} target="_blank" rel="noopener">
          Watch &amp; Listen
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .cc-itm {
    padding: 60px clamp(24px, 20vw, 390px);
  }
  .cc-itm-frame {
    position: relative;
    max-width: 1318px;
    margin: 0 auto;
    min-height: 683px;
  }
  .cc-itm-photo {
    position: absolute;
    right: 0;
    top: 0;
    width: 80%;
    height: 683px;
    border-radius: 25px;
    background-image: url('/assets/in-the-media-bg.png');
    background-size: cover;
    background-position: center;
  }
  .cc-itm-card {
    position: absolute;
    left: 0;
    top: 82px;
    width: 48%;
    min-width: 360px;
    border-radius: 25px;
    background: rgba(28, 27, 45, 0.92);
    padding: 50px;
    display: flex;
    flex-direction: column;
    gap: 22px;
    box-shadow: 0 0 80px 0 #171625;
  }
  .cc-itm-logo {
    width: 100px;
    opacity: 0.95;
  }
  .cc-itm-headline {
    font-family: var(--cc-font-display);
    font-weight: 500;
    font-size: clamp(36px, 4.2vw, 64px);
    line-height: 1;
    color: var(--cc-mirinda-deep);
    margin: 0;
  }
  .cc-itm-card p {
    margin: 0;
    font-family: var(--cc-font-body);
    font-size: 20px;
    line-height: 1.6;
    color: var(--cc-pearl);
  }
  .cc-itm-cta {
    margin-top: 10px;
  }
  @media (max-width: 900px) {
    .cc-itm {
      padding: 40px 24px;
    }
    .cc-itm-frame {
      min-height: 0;
    }
    .cc-itm-photo {
      position: relative;
      width: 100%;
      height: 280px;
      margin-bottom: 24px;
    }
    .cc-itm-card {
      position: relative;
      top: 0;
      width: 100%;
      min-width: 0;
      padding: 30px;
    }
  }
</style>
