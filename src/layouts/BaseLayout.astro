---
/**
 * BaseLayout — chriscarolan.com shell.
 * Loads Brand Alchemy design tokens (Kameron + Roboto + Poppins via colors_and_type.css)
 * and Tailwind utilities. Tailwind is layout-only; brand colors and typography come
 * from CSS custom properties in colors_and_type.css.
 */
import { SITE } from '../lib/site';
import '../styles/colors_and_type.css';
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  path: string;
}

const {
  title,
  description = SITE.description,
  path,
} = Astro.props;

const fullTitle = path === '/' ? `${SITE.name} — Business Transformation Advisor for the AI Era` : `${title} — ${SITE.name}`;
const canonicalUrl = `${SITE.url}${path}`;
const ogImage = `${SITE.url}/assets/og-image.png`;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Favicons (Brand Alchemy final deliverable).
         The navy-tile "dark" artwork is self-contained and legible on both light
         and dark browser tab bars, so it is the default/fallback. The transparent
         orange-mark "light" artwork is served only to dark-mode UAs, where it pops
         against a dark tab bar. apple-touch-icon uses the opaque navy tile (iOS
         renders transparent icons on black). -->
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon/favicon-32-dark.png" />
    <link rel="icon" type="image/png" sizes="64x64" href="/favicon/favicon-64-dark.png" />
    <link rel="icon" type="image/png" sizes="512x512" href="/favicon/favicon-512-dark.png" />
    <link rel="icon" type="image/png" sizes="32x32" media="(prefers-color-scheme: dark)" href="/favicon/favicon-32-light.png" />
    <link rel="icon" type="image/png" sizes="64x64" media="(prefers-color-scheme: dark)" href="/favicon/favicon-64-light.png" />
    <link rel="icon" type="image/svg+xml" href="/assets/logo-cc-mark-orange.svg" />
    <link rel="apple-touch-icon" sizes="512x512" href="/favicon/favicon-512-dark.png" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${SITE.name} — ${SITE.tagline}`} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body>
    <main id="main">
      <slot />
    </main>
  </body>
</html>
